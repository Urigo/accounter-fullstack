; Database variables
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=accounter
POSTGRES_SSL='0'

; Authentication
AUTHORIZED_USERS='{"admin":"SECRET","accountant":"SECRET"}'

; seed (Part of the seed script)
# SEED_BANK_ACCOUNT_NUMBER=1234567890
# SEED_BANK_NUMBER=12
# SEED_BRANCH_NUMBER=123
# SEED_CREDIT_CARD_LAST4DIGITS=1234
# SEED_CURRENCIES=USD,ILS

; Local entities (Auto-generated if using the seed script on setup)
DEFAULT_FINANCIAL_ENTITY_ID=00000000-0000-0000-0000-000000000000

; HaPoalim bank scraper creds
USER_CODE=BG98920
PASSWORD=pass
IS_BUSINESS_ACCOUNT=false

; Isracard creds
ISRACARD_ID=123456789
ISRACARD_PASSWORD=pass
ISRACARD_6_DIGITS=123456

; CAL creditcard creds
CAL_USERNAME=
CAL_PASSWORD=
CAL_LAST4DIGITS=1234,5678,9012

; Discount bank creds
DISCOUNT_ID=
DISCOUNT_PASSWORD=
# DISCOUNT_CODE=

; American Express creditcard creds
AMEX_ID=amex-id
AMEX_PASSWORD=amex-pass
AMEX_6_DIGITS=123456

; MAX creditcard creds
MAX_USERNAME=max-username
MAX_PASSWORD=max-password

; Hashavshevet (For integration with the company\'s financial cloud)
WIZ_COMPANY=company-id
WIZ_KEY=some-long-token

; Green Invoice (Financial documents issuing provider)
GREEN_INVOICE_ID=id
GREEN_INVOICE_SECRET=secret

; Cloudinary (For uploading files)
CLOUDINARY_NAME=name
CLOUDINARY_API_KEY=key
CLOUDINARY_API_SECRET=secret

; hive
HIVE_TOKEN=hiveToken

; Mesh dev (Richer logs on the dev environment)
DEBUG=1

; google drive (for uploading files from shared drive)
GOOGLE_DRIVE_API_KEY=googleDriveApiKey

; Anthropic AI (for OCR)
ANTHROPIC_API_KEY=anthropicApiKey

; Gmail OAuth2 Credentials
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_LABEL_PATH=path/to/label # e.g., accounter/documents

; Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your_project_id
GOOGLE_APPLICATION_CREDENTIALS=path_to_your_service_account_key.json
PUBSUB_TOPIC=gmail_notifications
PUBSUB_SUBSCRIPTION=gmail_notifications_sub

# Auth0 Configuration (JWT Verification)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.accounter.com

# Auth0 Frontend (SPA Application)
AUTH0_FRONTEND_CLIENT_ID=your_spa_client_id

# Auth0 Management API (M2M Application)
AUTH0_CLIENT_ID=your_m2m_client_id
AUTH0_CLIENT_SECRET=your_m2m_client_secret
AUTH0_MANAGEMENT_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# Note: No JWT secrets needed - Auth0 uses RS256 asymmetric signing
# Public keys fetched from: https://{domain}/.well-known/jwks.json
