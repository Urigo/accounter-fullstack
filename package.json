{
  "name": "accounter-monorepo",
  "type": "module",
  "license": "MIT",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "!packages/old-accounter"
    ]
  },
  "packageManager": "yarn@4.17.1",
  "engines": {
    "node": "26.5.0"
  },
  "scripts": {
    "build": "yarn generate && yarn build:tools && yarn build:main",
    "build:main": "yarn workspaces foreach --all --parallel --include @accounter/client --include @accounter/server --include @accounter/scraper-app --include @accounter-helper/scraper-local-app run build",
    "build:tools": "yarn workspaces foreach --all --parallel --exclude @accounter/client --exclude @accounter/client --exclude @accounter-helper/scraper-local-app --exclude accounter-monorepo run build",
    "db:migrate": "yarn migration:run",
    "encrypt-password": "node scripts/encrypt-password.mjs",
    "generate": "concurrently -c blue,green -n GraphQL,SQL \"yarn generate:graphql\" \"yarn generate:sql\"",
    "generate:all": "yarn generate",
    "generate:graphql": "yarn generate:graphql:clear; graphql-codegen",
    "generate:graphql:clear": "rimraf schema.graphql packages/server/**/__generated__/types.ts packages/client/src/gql/ packages/gmail-listener/src/gql/ packages/scraper-app/src/server/gql/ packages/email-ingestion-gateway/src/gql/",
    "generate:watch": "concurrently -c blue,green -n GraphQL,SQL \"yarn generate:graphql --watch\" \"yarn generate:sql:watch\"",
    "graphql:coverage": "yarn graphql-inspector coverage './packages/client/src/**/*.{ts,tsx}' './schema.graphql'",
    "graphql:validate": "yarn graphql-inspector validate './packages/client/src/**/*.{ts,tsx}' './schema.graphql'",
    "lint": "eslint --cache --cache-location node_modules/.cache/.eslintcache .",
    "local:setup": "docker-compose -f ./docker/docker-compose.dev.yml up -d --wait && yarn setup",
    "mesh:artifacts-rename": "yarn node ./scripts/mesh-artifacts-rename.mjs",
    "migration:check-conflicts": "node --import ./scripts/register-esm.js ./scripts/check-migration-conflicts.ts",
    "pre-commit": "lint-staged",
    "prettier:check": "prettier --cache --check .",
    "prettier:fix": "prettier --cache --write --list-different .",
    "release": "yarn build && changeset publish",
    "scrape": "yarn workspace @accounter-helper/scraper-local-app start",
    "seed:admin-context": "yarn workspace @accounter/server seed:admin",
    "seed:production": "tsx scripts/seed.ts",
    "seed:reset-staging": "echo \"DESTRUCTIVE: Implement seed reset script as needed\"",
    "seed:staging-demo": "tsx scripts/seed-demo-data.ts",
    "setup": "yarn db:init && yarn generate",
    "test": "vitest run --project unit",
    "test:demo-seed": "vitest run --project demo-seed",
    "test:integration": "vitest run --project unit --project integration",
    "validate:demo": "tsx packages/server/src/demo-fixtures/validate-demo-data.ts"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "1.17.3",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.1",
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "10.0.1",
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/client-preset": "6.1.0",
    "@graphql-codegen/graphql-modules-preset": "6.1.0",
    "@graphql-codegen/schema-ast": "6.1.0",
    "@graphql-codegen/typescript": "6.1.0",
    "@graphql-codegen/typescript-graphql-request": "7.1.0",
    "@graphql-codegen/typescript-resolvers": "6.1.0",
    "@graphql-eslint/eslint-plugin": "4.4.0",
    "@graphql-hive/cli": "0.60.3",
    "@graphql-inspector/cli": "6.0.8",
    "@parcel/watcher": "2.6.0",
    "@pgtyped/cli": "2.4.3",
    "@pgtyped/runtime": "2.4.2",
    "@theguild/eslint-config": "0.13.4",
    "@theguild/prettier-config": "3.0.1",
    "@types/node": "25.9.5",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "@vitest/coverage-v8": "4.1.10",
    "bob-the-bundler": "7.0.1",
    "concurrently": "10.0.3",
    "dotenv": "17.4.2",
    "eslint": "10.7.0",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-sonarjs": "4.2.0",
    "eslint-plugin-unicorn": "72.0.0",
    "glob": "13.0.6",
    "globals": "17.7.0",
    "graphql": "16.14.2",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "pg": "8.22.0",
    "prettier": "3.9.5",
    "prettier-plugin-sql": "0.20.0",
    "rimraf": "6.1.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "resolutions": {
    "@slonik/pg-driver@npm:^49.10.7": "patch:@slonik/pg-driver@npm%3A49.10.7#~/.yarn/patches/@slonik-pg-driver-npm-49.10.7-7bd58c1a0b.patch",
    "graphql": "16.14.2"
  },
  "lint-staged": {
    "*.--write": "prettier --write"
  },
  "puppeteer": {
    "skipDownload": true
  }
}
