{
  "name": "@accounter/email-ingestion-gateway",
  "version": "0.1.0",
  "type": "module",
  "description": "Cloudflare Email to Server ingestion gateway for multi-tenant email document ingestion",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Urigo/accounter-fullstack.git",
    "directory": "packages/email-ingestion-gateway"
  },
  "homepage": "https://github.com/Urigo/accounter-fullstack/packages/email-ingestion-gateway#readme",
  "bugs": {
    "url": "https://github.com/Urigo/accounter-fullstack/issues"
  },
  "author": "Gil Gardosh <gilgardosh@gmail.com>",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": "26.4.0"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "email",
    "ingestion",
    "gateway",
    "documents",
    "accounter"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "docker:build": "docker build -f packages/email-ingestion-gateway/DockerFile -t email-ingestion-gateway .",
    "docker:run": "docker run -it --rm --env-file ./packages/email-ingestion-gateway/.env email-ingestion-gateway",
    "email-ingestion-gateway:build": "yarn build",
    "email-ingestion-gateway:build:prod": "yarn generate && yarn build",
    "email-ingestion-gateway:dev": "yarn dev",
    "email-ingestion-gateway:start": "yarn start",
    "email-ingestion-gateway:worker:deploy": "yarn worker:deploy",
    "email-ingestion-gateway:worker:dev": "yarn worker:dev",
    "generate": "yarn generate:graphql",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "worker:deploy": "wrangler deploy",
    "worker:dev": "wrangler dev"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "graphql": "16.14.2",
    "graphql-request": "7.4.0",
    "inline-css": "4.0.3",
    "playwright": "1.61.1",
    "postal-mime": "2.7.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/inline-css": "3.0.4",
    "@types/node": "25.9.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "wrangler": "4.104.0"
  }
}
