# /packages/gmail-listener/Dockerfile
# Replace 1.42.0 with your actual Playwright version
FROM mcr.microsoft.com/playwright:v1.58.2

WORKDIR /app

# Copy the entire monorepo into the container
COPY . .

# Run yarn install from the root (installs all workspace dependencies)
RUN yarn install --immutable

# Run your specific workspace build commands
RUN yarn generate:graphql
RUN yarn workspace @accounter/gmail-listener build

# Start the specific workspace service
CMD ["yarn", "workspace", "@accounter/gmail-listener", "start"]
